{
  "name": "launcher",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.crunchydl.launcher",
    "productName": "CrunchyDL Launcher",
    "win": {
      "target": "portable",
      "icon": "icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "icon.png"
    },
    "files": [
      "index.js",
      "translations.js",
      "icon.png",
      "package.json"
    ]
  },
  "dependencies": {
    "open": "^8.4.2",
    "shelljs": "^0.8.5"
  },
  "devDependencies": {
    "electron": "^41.0.4",
    "electron-builder": "^26.8.1"
  }
}
